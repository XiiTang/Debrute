{
  "name": "debrute",
  "version": "0.0.2",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "description": "Debrute browser-first local creative production workbench.",
  "packageManager": "pnpm@11.2.2",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=11.2.2 <12"
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json && node scripts/copy-runtime-assets.mjs && pnpm --filter @debrute/desktop build",
    "clean": "node scripts/clean.mjs",
    "icons:sync": "node scripts/sync-project-icons.mjs",
    "pack": "pnpm --filter @debrute/desktop pack",
    "package:runtime-cli": "node scripts/package-debrute-cli.mjs",
    "package:photoshop-uxp-plugin": "node scripts/package-photoshop-uxp-plugin.mjs",
    "package:photoshop-cep-plugin": "node scripts/package-photoshop-cep-plugin.mjs",
    "package:photoshop-plugin": "pnpm package:photoshop-uxp-plugin && pnpm package:photoshop-cep-plugin",
    "dist": "pnpm --filter @debrute/desktop dist",
    "check": "tsc -b tsconfig.build.json --pretty false",
    "dev": "tsx scripts/dev-workbench.ts",
    "dev:web": "pnpm --filter @debrute/web dev",
    "dev:daemon": "pnpm --filter @debrute/daemon dev",
    "dev:electron": "pnpm --filter @debrute/desktop dev:electron",
    "preview": "pnpm --filter @debrute/web preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "diagnose:canvas-pan": "node scripts/canvas-pan-roundtrip-diagnostic.mjs",
    "lint:arch": "node scripts/check-architecture.mjs",
    "doctor": "node scripts/doctor.mjs",
    "verify": "pnpm doctor && pnpm check && pnpm test && pnpm lint:arch && pnpm build"
  },
  "dependencies": {
    "@debrute/workbench-runtime": "workspace:*"
  },
  "devDependencies": {
    "@debrute/architecture-rules": "workspace:*",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^24.13.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@yao-pkg/pkg": "^6.20.0",
    "adm-zip": "^0.5.17",
    "electron-builder": "^26.15.2",
    "esbuild": "^0.28.0",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.0.16",
    "yaml": "^2.9.0"
  }
}
