{
  "name": "axis",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "description": "AXIS browser-first local creative production workbench.",
  "packageManager": "pnpm@11.2.2",
  "engines": {
    "node": ">=22",
    "pnpm": ">=11.2.2 <12"
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json && node scripts/copy-runtime-assets.mjs && pnpm --filter @axis/desktop build",
    "clean": "node scripts/clean.mjs",
    "pack": "pnpm --filter @axis/desktop pack",
    "package:cli": "node scripts/package-axis-cli.mjs",
    "package:cli:all": "node scripts/package-axis-cli.mjs --all",
    "dist": "pnpm --filter @axis/desktop dist",
    "check": "tsc -b tsconfig.build.json --pretty false",
    "dev": "tsx scripts/dev-workbench.ts",
    "dev:web": "pnpm --filter @axis/web dev",
    "dev:daemon": "pnpm --filter @axis/daemon dev",
    "dev:electron": "pnpm --filter @axis/desktop dev:electron",
    "preview": "pnpm --filter @axis/web preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:arch": "node scripts/check-architecture.mjs",
    "doctor": "node scripts/doctor.mjs",
    "verify": "pnpm doctor && pnpm check && pnpm test && pnpm lint:arch && pnpm build"
  },
  "dependencies": {
    "@axis/workbench-runtime": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitejs/plugin-react": "^5.1.1",
    "@yao-pkg/pkg": "^6.20.0",
    "adm-zip": "^0.5.17",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vitest": "^4.0.16"
  }
}
