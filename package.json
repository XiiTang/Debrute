{
  "name": "debrute",
  "version": "0.0.3",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "description": "Debrute browser-first local creative production workbench.",
  "packageManager": "pnpm@11.2.2",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=11.2.2 <12"
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json && node scripts/copy-runtime-assets.mjs && pnpm --filter @debrute/desktop build",
    "clean": "node scripts/clean.mjs",
    "icons:sync": "node scripts/sync-project-icons.mjs",
    "pack": "pnpm --filter @debrute/desktop pack",
    "package:runtime-cli": "node scripts/package-debrute-cli.mjs",
    "package:photoshop-uxp-plugin": "node scripts/package-photoshop-uxp-plugin.mjs",
    "package:photoshop-cep-plugin": "node scripts/package-photoshop-cep-plugin.mjs",
    "package:photoshop-plugin": "pnpm package:photoshop-uxp-plugin && pnpm package:photoshop-cep-plugin",
    "dist": "pnpm --filter @debrute/desktop dist",
    "check": "tsc -b tsconfig.build.json --pretty false",
    "dev": "tsx scripts/dev-workbench.ts",
    "dev:daemon": "pnpm --filter @debrute/daemon dev",
    "dev:electron": "pnpm --filter @debrute/desktop dev:electron",
    "preview": "pnpm --filter @debrute/web preview",
    "test": "vitest run",
    "test:unit": "vitest run --project=unit-* --project=contracts",
    "test:dom": "vitest run --project=dom-web",
    "test:integration": "vitest run --project=integration",
    "test:system": "vitest run --project=system",
    "test:release": "vitest run --project=release",
    "test:watch": "vitest --project=unit-* --project=contracts --project=dom-web",
    "test:profile": "vitest run",
    "test:stability": "vitest run --sequence.shuffle.files --sequence.seed=104729 && vitest run --sequence.shuffle.files --sequence.seed=130363 && vitest run --sequence.shuffle.files --sequence.seed=155921",
    "test:coverage": "vitest run --coverage --project=unit-* --project=dom-web --project=contracts --project=integration",
    "test:canvas-text": "vitest run --tagsFilter=canvas-text",
    "test:layout": "tsx scripts/check-test-layout.ts",
    "verify:browser": "node scripts/verify-workbench-browser.mjs",
    "diagnose:canvas-pan": "node scripts/canvas-pan-roundtrip-diagnostic.mjs",
    "lint:arch": "node scripts/check-architecture.mjs",
    "doctor": "node scripts/doctor.mjs",
    "verify": "pnpm doctor && pnpm check && pnpm test && pnpm lint:arch && pnpm build"
  },
  "dependencies": {
    "@debrute/workbench-runtime": "workspace:*"
  },
  "devDependencies": {
    "@debrute/architecture-rules": "workspace:*",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^24.13.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "@yao-pkg/pkg": "^6.21.0",
    "adm-zip": "^0.5.18",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.3",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10",
    "yaml": "^2.9.0"
  }
}
