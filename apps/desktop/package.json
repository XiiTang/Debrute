{
  "name": "@axis/desktop",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": true,
  "type": "commonjs",
  "description": "Optional AXIS Electron shell.",
  "author": "AXIS",
  "main": "dist-electron/main.js",
  "scripts": {
    "build": "pnpm --filter @axis/web build && tsc -p tsconfig.electron.json --noEmit && node scripts/bundle-electron.mjs",
    "build:electron": "node scripts/bundle-electron.mjs",
    "build:electron:dev": "node scripts/bundle-electron.mjs --skip-web-dist",
    "pack": "pnpm build && electron-builder --dir",
    "dist": "pnpm build && electron-builder",
    "dev:electron": "tsx ../../scripts/dev-electron-workbench.ts"
  },
  "build": {
    "appId": "dev.axis.desktop",
    "productName": "AXIS",
    "electronVersion": "39.2.7",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "XiiTang",
        "repo": "AXIS",
        "releaseType": "release"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dir",
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "dependencies": {
    "@axis/app-protocol": "workspace:*",
    "@axis/app-server": "workspace:*",
    "@axis/daemon": "workspace:*",
    "@axis/project-core": "workspace:*",
    "@axis/workbench-runtime": "workspace:*"
  },
  "devDependencies": {
    "electron": "39.2.7",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.27.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.0"
  }
}
