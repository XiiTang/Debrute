{
  "name": "@debrute/desktop",
  "version": "0.0.1",
  "license": "Apache-2.0",
  "private": true,
  "type": "commonjs",
  "description": "Optional Debrute Electron shell.",
  "author": "Debrute",
  "main": "dist-electron/main.js",
  "scripts": {
    "build": "pnpm --workspace-root icons:sync && pnpm --filter @debrute/web build && tsc -p tsconfig.electron.json --noEmit && node scripts/bundle-electron.mjs",
    "build:electron": "pnpm --workspace-root icons:sync && node scripts/bundle-electron.mjs",
    "build:electron:dev": "pnpm --workspace-root icons:sync && node scripts/bundle-electron.mjs --skip-web-dist",
    "pack": "pnpm build && electron-builder --dir",
    "dist": "pnpm build && electron-builder",
    "dev:electron": "tsx ../../scripts/dev-electron-workbench.ts"
  },
  "build": {
    "appId": "dev.debrute.desktop",
    "productName": "Debrute",
    "electronVersion": "42.4.0",
    "asar": true,
    "afterPack": "scripts/package-sharp-runtime.mjs",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "XiiTang",
        "repo": "Debrute",
        "releaseType": "release"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "artifactName": "debrute-desktop-${version}-macos-${arch}.${ext}",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "artifactName": "debrute-desktop-${version}-windows-${arch}.${ext}",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "artifactName": "debrute-desktop-${version}-linux-${arch}.${ext}",
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    }
  },
  "dependencies": {
    "@debrute/app-protocol": "workspace:*",
    "@debrute/project-core": "workspace:*",
    "@debrute/workbench-runtime": "workspace:*",
    "electron-updater": "^6.8.9",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "electron": "42.4.0",
    "electron-builder": "^26.15.2",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
