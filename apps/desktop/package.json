{
  "name": "@debrute/desktop",
  "version": "0.0.2",
  "license": "Apache-2.0",
  "private": true,
  "type": "commonjs",
  "description": "Optional Debrute Electron shell.",
  "author": "Debrute",
  "main": "dist-electron/main.js",
  "scripts": {
    "build": "pnpm --filter @debrute/web build && tsc -p tsconfig.electron.json --noEmit && node scripts/bundle-electron.mjs",
    "build:electron": "node scripts/bundle-electron.mjs",
    "build:electron:dev": "node scripts/bundle-electron.mjs --skip-web-dist",
    "pack": "pnpm build && electron-builder --dir",
    "dist": "pnpm build && electron-builder",
    "dev:electron": "tsx ../../scripts/dev-electron-workbench.ts"
  },
    "build": {
    "appId": "io.github.xiitang.debrute",
    "productName": "Debrute",
    "executableName": "debrute",
    "electronVersion": "42.4.0",
    "asar": true,
    "asarUnpack": [
      "dist-electron/runtime-host.cjs",
      "dist-electron/canvas-feedback-render-worker.cjs",
      "dist-electron/product-replacement-helper.cjs",
      "dist-electron/runtime-product/**"
    ],
    "afterPack": "scripts/package-sharp-runtime.mjs",
    "afterSign": "scripts/notarize-macos-app.cjs",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "XiiTang",
        "repo": "Debrute",
        "releaseType": "release"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "artifactName": "debrute-desktop-${version}-macos-${arch}.${ext}",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "notarize": false,
      "target": [
        "dmg"
      ]
    },
    "dmg": {
      "sign": true
    },
    "win": {
      "artifactName": "debrute-desktop-${version}-windows-${arch}.${ext}",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "artifactName": "debrute-desktop-${version}-linux-x64.${ext}",
      "target": [
        "AppImage"
      ],
      "category": "Utility",
      "syncDesktopName": true
    }
  },
  "dependencies": {
    "@debrute/app-protocol": "workspace:*",
    "@debrute/project-core": "workspace:*",
    "@debrute/workbench-runtime": "workspace:*",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "electron": "42.4.0",
    "electron-builder": "^26.15.2",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
