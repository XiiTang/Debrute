{
  "name": "@debrute/desktop",
  "version": "0.0.1",
  "license": "Apache-2.0",
  "private": true,
  "type": "commonjs",
  "description": "Optional Debrute Electron shell.",
  "author": "Debrute",
  "main": "dist-electron/main.js",
  "scripts": {
    "build": "pnpm --filter @debrute/web build && tsc -p tsconfig.electron.json --noEmit && node scripts/bundle-electron.mjs",
    "build:electron": "node scripts/bundle-electron.mjs",
    "build:electron:dev": "node scripts/bundle-electron.mjs --skip-web-dist",
    "pack": "pnpm build && electron-builder --dir",
    "dist": "pnpm build && electron-builder",
    "dev:electron": "tsx ../../scripts/dev-electron-workbench.ts"
  },
  "build": {
    "appId": "dev.debrute.desktop",
    "productName": "Debrute",
    "electronVersion": "39.2.7",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dir",
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    }
  },
  "dependencies": {
    "@debrute/app-protocol": "workspace:*",
    "@debrute/app-server": "workspace:*",
    "@debrute/daemon": "workspace:*",
    "@debrute/project-core": "workspace:*",
    "@debrute/workbench-runtime": "workspace:*"
  },
  "devDependencies": {
    "electron": "39.2.7",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.27.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.0"
  }
}
