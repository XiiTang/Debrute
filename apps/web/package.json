{
  "name": "@debrute/web",
  "version": "0.0.1",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "description": "Debrute browser workbench.",
  "scripts": {
    "build": "pnpm --workspace-root icons:sync && tsc --noEmit && vite build",
    "check": "tsc --noEmit --pretty false",
    "dev": "vite --host 127.0.0.1",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@debrute/app-protocol": "workspace:*",
    "@debrute/canvas-core": "workspace:*",
    "@debrute/project-core": "workspace:*",
    "@monaco-editor/react": "^4.7.0",
    "lucide-react": "^1.17.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
