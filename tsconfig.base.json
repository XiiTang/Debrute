{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["node"],
    "rootDir": ".",
    "paths": {
      "@debrute/app-protocol": ["./packages/app-protocol/src/index.ts"],
      "@debrute/architecture-rules": ["./packages/architecture-rules/src/index.mjs"],
      "@debrute/capability-core": ["./packages/capability-core/src/index.ts"],
      "@debrute/project-core/projectCacheKeys": ["./packages/project-core/src/projectCacheKeys.ts"],
      "@debrute/project-core/projectTextFileTypes": ["./packages/project-core/src/projectTextFileTypes.ts"],
      "@debrute/project-core": ["./packages/project-core/src/index.ts"],
      "@debrute/runtime-control-client": ["./packages/runtime-control-client/src/index.ts"],
      "@debrute/canvas-core": ["./packages/canvas-core/src/index.ts"],
      "@debrute/canvas-map-core": ["./packages/canvas-map-core/src/index.ts"],
      "@debrute/photoshop-bridge-plugin-core": ["./packages/photoshop-bridge-plugin-core/src/index.ts"]
    }
  }
}
